{
    "name": "lingoda/thinkingcap-client",
    "description": "Lingoda Thinkingcap Bundle",
    "type": "symfony-bundle",
    "require-dev": {
        "laminas/laminas-code": "^4.5",
        "phpspec/phpspec": "^7.2 || ^8.0",
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0 || ^8.0"
    },
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "nyholm/psr7": "^1.7",
        "phpro/soap-client": "^4.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Lingoda\\ThinkingcapBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lingoda\\ThinkingcapBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
